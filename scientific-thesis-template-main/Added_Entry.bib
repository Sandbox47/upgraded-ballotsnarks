
@incollection{dunkelman_families_2022,
	address = {Cham},
	title = {Families of {SNARK}-{Friendly} 2-{Chains} of {Elliptic} {Curves}},
	volume = {13276},
	isbn = {978-3-031-07084-6 978-3-031-07085-3},
	url = {https://link.springer.com/10.1007/978-3-031-07085-3_13},
	abstract = {At CANS’20, El Housni and Guillevic introduced a new 2-chain of pairing-friendly elliptic curves for recursive zero-knowledge Succinct Non-interactive ARguments of Knowledge (zk-SNARKs) made of the former BLS12-377 curve (a Barreto–Lynn–Scott curve over a 377bit prime ﬁeld) and the new BW6-761 curve (a Brezing–Weng curve of embedding degree 6 over a 761-bit prime ﬁeld). First we generalise the curve construction, the pairing formulas (e : G1 × G2 → GT ) and the group operations to any BW6 curve deﬁned on top of any BLS12 curve, forming a family of 2-chain pairing-friendly curves. Second, we investigate other possible 2-chain families made on top of the BLS12 and BLS24 curves. We compare BW6 to Cocks–Pinch curves of higher embedding degrees 8 and 12 (CP8, CP12) at the 128-bit security level. We derive formulas for eﬃcient optimal ate and optimal Tate pairings on our new CP curves. We show that for both BLS12 and BLS24, the BW6 construction always gives the fastest pairing and curve arithmetic compared to Cocks-Pinch curves. Finally, we suggest a short list of curves suitable for Groth16 and KZG-based universal SNARKs and present an optimized implementation of these curves. Based on Groth16 and PlonK (a KZG-based SNARK) implementations in the gnark ecosystem, we obtain that the BLS12-377/BW6-761 pair is optimized for the former while the BLS24-315/BW6-672 pair is optimized for the latter.},
	language = {en},
	urldate = {2025-04-28},
	booktitle = {Advances in {Cryptology} – {EUROCRYPT} 2022},
	publisher = {Springer International Publishing},
	author = {El Housni, Youssef and Guillevic, Aurore},
	editor = {Dunkelman, Orr and Dziembowski, Stefan},
	year = {2022},
	doi = {10.1007/978-3-031-07085-3_13},
	note = {Series Title: Lecture Notes in Computer Science},
	pages = {367--396},
	file = {PDF:/home/felix-roehr/snap/zotero-snap/common/Zotero/storage/FY8GYSI2/El Housni and Guillevic - 2022 - Families of SNARK-Friendly 2-Chains of Elliptic Curves.pdf:application/pdf},
}

@article{kosba_cc_2015,
	title = {{C}\ensuremath{\emptyset}{C}\ensuremath{\emptyset}: {A} {Framework} for {Building} {Composable} {Zero}-{Knowledge} {Proofs}},
	abstract = {Non-interactive zero-knowledge proofs are a powerful cryptographic primitive used in privacypreserving protocols. We design and build {C}\ensuremath{\emptyset}{C}\ensuremath{\emptyset}, the ﬁrst system enabling developers to build eﬃcient, composable, non-interactive zero-knowledge proofs for generic, user-deﬁned statements. \{C\}{\textbackslash}ensuremath\{{\textbackslash}emptyset\}\{C\}{\textbackslash}ensuremath\{{\textbackslash}emptyset\} extends state-of-the-art SNARK constructions by applying known strengthening transformations to yield UC-composable zero-knowledge proofs suitable for modular use in larger cryptographic protocols.},
	language = {en},
	journal = {Cryptology ePrint Archive, Report 2015/1093},
	author = {Kosba, Ahmed and Zhao, Zhichao and Miller, Andrew and Qian, Yi and Chan, T-H Hubert and Papamanthou, Charalampos and Pass, Rafael and Shi, Elaine},
	year = {2015},
	file = {PDF:/home/felix-roehr/snap/zotero-snap/common/Zotero/storage/MMVE44FH/Kosba et al. - {C}\ensuremath{\emptyset}{C}\ensuremath{\emptyset} A Framework for Building Composable Zero-Knowledge Proofs.pdf:application/pdf},
}

