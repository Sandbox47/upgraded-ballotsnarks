@misc{cortier_fifty_2020,
	title = {Fifty {Shades} of {Ballot} {Privacy}: {Privacy} against a {Malicious} {Board}},
	shorttitle = {Fifty {Shades} of {Ballot} {Privacy}},
	url = {https://eprint.iacr.org/2020/127},
	abstract = {We propose a framework for the analysis of electronic voting schemes in the presence of malicious bulletin boards. We identify a spectrum of notions where the adversary is allowed to tamper with the bulletin board in ways that reflect practical deployment and usage considerations. To clarify the security guarantees provided by the different notions we establish a relation with simulation-based security with respect to a family of ideal functionalities. The ideal functionalities make clear the set of authorised attacker capabilities which makes it easier to understand and compare the associated levels of security. We then leverage this relation to show that each distinct level of ballot privacy entails some distinct form of individual verifiability. As an application, we study three protocols of the literature (Helios, Belenios, and Civitas) and identify the different levels of privacy they offer.},
	urldate = {2025-02-17},
	author = {Cortier, Véronique and Lallemand, Joseph and Warinschi, Bogdan},
	year = {2020},
	note = {Publication info: Preprint. MINOR revision.},
	keywords = {privacy, e-voting, protocols},
	file = {Full Text PDF:/home/felix-roehr/snap/zotero-snap/common/Zotero/storage/H68ZA3UR/Cortier et al. - 2020 - Fifty Shades of Ballot Privacy Privacy against a Malicious Board.pdf:application/pdf},
}

@inproceedings{cortier_sok_2016,
	address = {San Jose, CA},
	title = {{SoK}: {Verifiability} {Notions} for {E}-{Voting} {Protocols}},
	isbn = {978-1-5090-0824-7},
	shorttitle = {{SoK}},
	url = {http://ieeexplore.ieee.org/document/7546535/},
	doi = {10.1109/SP.2016.52},
	abstract = {There have been intensive research efforts in the last two decades or so to design and deploy electronic voting (e-voting) protocols/systems which allow voters and/or external auditors to check that the votes were counted correctly. This security property, which not least was motivated by numerous problems in even national elections, is called veriﬁability. It is meant to defend against voting devices and servers that have programming errors or are outright malicious. In order to properly evaluate and analyze e-voting protocols w.r.t. veriﬁability, one fundamental challenge has been to formally capture the meaning of this security property. While the ﬁrst formal deﬁnitions of veriﬁability were devised in the late 1980s already, new veriﬁability deﬁnitions are still being proposed. The deﬁnitions differ in various aspects, including the classes of protocols they capture and even their formulations of the very core of the meaning of veriﬁability. This is an unsatisfying state of affairs, leaving the research on the veriﬁability of e-voting protocols in a fuzzy state.},
	language = {en},
	urldate = {2025-02-17},
	booktitle = {2016 {IEEE} {Symposium} on {Security} and {Privacy} ({SP})},
	publisher = {IEEE},
	author = {Cortier, Veronique and Galindo, David and Kusters, Ralf and Muller, Johannes and Truderung, Tomasz},
	month = may,
	year = {2016},
	pages = {779--798},
	file = {PDF:/home/felix-roehr/snap/zotero-snap/common/Zotero/storage/2Q5BQ2LQ/Cortier et al. - 2016 - SoK Verifiability Notions for E-Voting Protocols.pdf:application/pdf},
}
