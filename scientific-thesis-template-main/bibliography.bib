@article{farashahi_faster_2024,
	title = {Faster {Complete} {Addition} {Laws} for {Montgomery} {Curves}},
	volume = {2024},
	copyright = {https://creativecommons.org/licenses/by/4.0},
	issn = {2569-2925},
	url = {https://tches.iacr.org/index.php/TCHES/article/view/11808},
	doi = {10.46586/tches.v2024.i4.737-762},
	abstract = {An addition law for an elliptic curve is complete if it is deﬁned for all possible pairs of input points on the elliptic curve. In Elliptic Curve Cryptography (ECC), a complete addition law provides a natural protection against side-channel attacks which are based on Simple Power Analysis (SPA). Montgomery curves are a speciﬁc family of elliptic curves that play a crucial role in ECC because of its well-known Montgomery ladder, particularly in the Elliptic Curve Diﬃe-Hellman Key Exchange (ECDHKE) protocol and the Elliptic Curve factorization Method (ECM). However, the complete addition law for Montgomery curves, as stated in the literature, has a computational cost of 14M + 2D, where M, D denote the costs of a ﬁeld multiplication and a ﬁeld multiplication by a constant, respectively. The lack of a competitive complete addition law has led implementers towards twisted Edwards curves, which oﬀer a complete addition law at a lower cost of 8M + 1D for appropriately chosen curve constants.},
	language = {en},
	number = {4},
	urldate = {2025-03-18},
	journal = {IACR Transactions on Cryptographic Hardware and Embedded Systems},
	author = {Farashahi, Reza Rezaeian and Fadavi, Mojtaba and Sabbaghian, Soheila},
	month = sep,
	year = {2024},
	pages = {737--762},
	file = {PDF:/home/felix-roehr/snap/zotero-snap/common/Zotero/storage/KTIW5QBL/Farashahi et al. - 2024 - Faster Complete Addition Laws for Montgomery Curves.pdf:application/pdf},
}

